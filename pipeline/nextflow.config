/*
 * Nextflow configuration for CVDash pipeline.
 *
 * Profiles:
 *   docker       - GCP Batch / local dev
 *   singularity  - Isambard HPC
 *   test         - CI/CD with minimal resources
 */

manifest {
    name            = 'cvdash-pipeline'
    author          = 'Oxford CVDash Team'
    description     = 'Somatic variant calling for neoantigen prediction'
    version         = '1.0.0'
    nextflowVersion = '>=24.04'
}

// Default resource limits (can be overridden per-process in main.nf)
process {
    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'FASTP' {
        cpus   = 4
        memory = '8 GB'
        time   = '30m'
    }
    withName: 'BWA_MEM2' {
        cpus   = 12
        memory = '32 GB'
        time   = '2h'
    }
    withName: 'MUTECT2' {
        cpus   = 4
        memory = '16 GB'
        time   = '3h'
    }
    withName: 'VEP_ANNOTATE' {
        cpus   = 2
        memory = '8 GB'
        time   = '1h'
    }
}

profiles {
    docker {
        docker.enabled       = true
        docker.runOptions     = '--platform linux/amd64'
    }
    singularity {
        singularity.enabled   = true
        singularity.autoMounts = true
        // Isambard-specific: use project scratch for temp files
        singularity.runOptions = '--bind /scratch,/projects'
    }
    test {
        docker.enabled = true
        process {
            cpus   = 1
            memory = '2 GB'
            time   = '10m'
        }
    }
}

// Timeline and trace reports
timeline {
    enabled = true
    file    = "${params.output_dir}/timeline.html"
}
trace {
    enabled = true
    file    = "${params.output_dir}/trace.tsv"
}
